Options -Indexes

# Block direct access to sensitive project files
<FilesMatch "(\.env|composer\.(json|lock)|CLAUDE\.md|structure\.txt|schema\.sql)">
    Require all denied
</FilesMatch>

RewriteEngine On
RewriteBase /

# Already targeting /public/ directly — leave as-is
RewriteCond %{REQUEST_URI} ^/public/
RewriteRule ^ - [L]

# Static file exists in public/ — serve it
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
RewriteRule ^(.*)$ public/$1 [L,QSA]

# Static directory exists in public/ — serve it
RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
RewriteRule ^(.*)$ public/$1 [L,QSA]

# Everything else goes through the front controller
RewriteRule ^(.*)$ public/index.php [L,QSA]
